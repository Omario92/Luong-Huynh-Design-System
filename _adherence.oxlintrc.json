      "--lh-bg",
      "--lh-bg-soft",
      "--lh-dur-base",
      "--lh-dur-fast",
      "--lh-dur-slow",
      "--lh-ease",
      "--lh-gutter",
      "--lh-line",
      "--lh-line-strong",
      "--lh-max",
      "--lh-muted",
      "--lh-panel",
